# This file is a template for backend/.env.
# Copy it as backend/.env and replace the placeholders with real values.
# backend/.env is ignored by Git because it contains private database credentials.
#
# Use this when teammates should connect their local backend to the same shared
# PostgresSQL database. Keep this example file in GitHub so evaluators and
# teammates understand the required structure without exposing secrets.

# JDBC URL for PostgresSQL.
# For Render external databases, use:
# jdbc:postgresql://<external-host>:5432/ride_management_db?sslmode=require
DATABASE_URL=jdbc:postgresql://<external-host>:5432/ride_management_db?sslmode=require

# Database username from the hosted PostgresSQL provider.
DATABASE_USERNAME=ride_user

# Database password from the hosted PostgresSQL provider.
DATABASE_PASSWORD=<shared-database-password>

# Secret used to sign JWT tokens. Use any long random string and keep it private.
JWT_SECRET=<shared-jwt-secret>
